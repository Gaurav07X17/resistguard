# ── ResistGuard Backend — Environment Variables ──────────────────────
# Copy this to .env and fill in your values. NEVER commit .env to git.

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/resistguard
MONGO_URI=

# JWT secret — use a long random string (32+ chars)
JWT_SECRET=
JWT_EXPIRE=7d

# Your Vercel frontend URL (no trailing slash)
# Example: https://resistguard.vercel.app
FRONTEND_URL=
